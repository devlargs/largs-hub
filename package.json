{
  "name": "largs-hub",
  "version": "0.1.13",
  "description": "An open-source workspace browser — manage all your web apps in one place",
  "main": "dist-electron/main.js",
  "scripts": {
    "vite:dev": "vite",
    "build": "tsc && vite build && tsc -p tsconfig.electron.json",
    "preview": "vite preview",
    "dev": "concurrently \"vite\" \"tsc -p tsconfig.electron.json --watch\" \"electron . --dev\"",
    "electron:build": "npm run build && electron-builder"
  },
  "keywords": [
    "electron",
    "workspace",
    "browser",
    "rambox-alternative"
  ],
  "author": "Ralph Largo",
  "license": "MIT",
  "dependencies": {
    "electron-store": "^8.2.0",
    "react-icons": "^5.6.0",
    "uuid": "^11.1.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.1.0",
    "electron": "^35.0.0",
    "electron-builder": "^25.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.1.0",
    "typescript": "^5.8.0",
    "vite": "^6.3.0"
  },
  "build": {
    "appId": "com.largshub.app",
    "productName": "Largs Hub",
    "icon": "assets/ico/icon.ico",
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "assets/ico/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis",
      "sign": false,
      "icon": "assets/ico/icon.ico"
    },
    "nsis": {
      "artifactName": "${productName} Setup.${ext}"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    },
    "publish": {
      "provider": "github",
      "owner": "devlargs",
      "repo": "largs-hub"
    }
  }
}
