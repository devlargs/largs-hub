{
  "name": "largs-hub",
  "version": "0.1.28",
  "description": "An open-source workspace browser — manage all your web apps in one place",
  "main": "dist-electron/main.js",
  "scripts": {
    "vite:dev": "vite",
    "build": "tsc && vite build && tsc -p tsconfig.electron.json",
    "preview": "vite preview",
    "dev": "concurrently \"vite\" \"tsc -p tsconfig.electron.json --watch\" \"electronmon . --dev\"",
    "electron:build": "npm run build && electron-builder",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.electron.json --noEmit && tsc -p tsconfig.test.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "electronmon": {
    "patterns": [
      "dist-electron/**"
    ]
  },
  "keywords": [
    "electron",
    "workspace",
    "browser",
    "rambox-alternative"
  ],
  "author": "Ralph Largo",
  "license": "MIT",
  "dependencies": {
    "electron-store": "^8.2.0",
    "react-icons": "^5.6.0",
    "uuid": "^11.1.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.1.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.1.0",
    "electron": "^35.0.0",
    "electron-builder": "^25.1.0",
    "electronmon": "^2.0.4",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.7.0",
    "prettier": "^3.9.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.1.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.63.0",
    "vite": "^6.3.0",
    "vitest": "^4.1.10"
  },
  "build": {
    "appId": "com.largshub.app",
    "productName": "Largs Hub",
    "icon": "assets/ico/icon.ico",
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "assets/ico/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis",
      "sign": false,
      "icon": "assets/ico/icon.ico"
    },
    "nsis": {
      "artifactName": "${productName} Setup.${ext}"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    },
    "publish": {
      "provider": "github",
      "owner": "devlargs",
      "repo": "largs-hub"
    }
  }
}
